{
  "name": "ethara-task-manager",
  "version": "1.0.0",
  "description": "Team Task Manager — collaborative project & task management",
  "scripts": {
    "dev:server": "python3 -m uvicorn server.main:app --reload --port 5000",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "pip3 install -r requirements.txt && cd client && npm install --include=dev && npm run build",
    "start": "python3 -m uvicorn server.main:app --host 0.0.0.0 --port ${PORT:-5000}",
    "postinstall": "cd client && npm install --include=dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
